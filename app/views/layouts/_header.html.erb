<%# app/views/layouts/_header.html.erb %>
<header 
  data-controller="scroll-header" 
  data-action="scroll@window->scroll-header#onScroll"
  class="sticky top-0 z-40 px-6 py-8 transition-all duration-300 ease-in-out"
>
  <div class="max-w-md mx-auto flex items-center justify-between">
    <div class="flex items-center gap-4">
      <h1 class="text-xl font-black text-slate-900">
        <%= @page_title || "Money Planner" %>
      </h1>
    </div>
    
    <%# Avatar User with Dropdown %>
    <div class="relative" data-controller="dropdown">
      <button data-action="click->dropdown#toggle" class="w-10 h-10 border-2 border-slate-900 rounded-full bg-indigo-400 overflow-hidden focus:outline-none hover:scale-105 transition-transform block">
        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=<%= current_user.email if user_signed_in? %>" alt="avatar" class="w-full h-full object-cover">
      </button>

      <div data-dropdown-target="menu" class="hidden absolute right-0 top-12 w-48 bg-white border-2 border-slate-900 rounded-2xl shadow-[4px_4px_0_0_rgba(0,0,0,1)] overflow-hidden z-50">
        <%= link_to categories_path, class: "flex items-center gap-3 px-4 py-3 font-bold text-sm text-slate-900 hover:bg-slate-100 border-b-2 border-slate-900" do %>
          <i data-lucide="shapes" class="w-4 h-4"></i>
          Kategori
        <% end %>
        <%= link_to edit_settings_path, class: "flex items-center gap-3 px-4 py-3 font-bold text-sm text-slate-900 hover:bg-slate-100 border-b-2 border-slate-900" do %>
          <i data-lucide="settings" class="w-4 h-4"></i>
          Pengaturan
        <% end %>
        <%= button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center gap-3 px-4 py-3 font-bold text-sm text-rose-500 hover:bg-slate-100 text-left", data: { turbo: false } do %>
          <i data-lucide="log-out" class="w-4 h-4"></i>
          Keluar
        <% end %>
      </div>
    </div>
  </div>
</header>