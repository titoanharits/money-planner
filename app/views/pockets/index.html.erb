<%# app/views/pockets/index.html.erb %>
<div class="pb-24 space-y-6">
  <div class="flex justify-between items-center px-1 mb-2">
    <h3 class="font-black text-xs uppercase tracking-widest text-slate-900">Kantong Saya</h3>
    <span class="text-xs font-bold text-slate-500"><%= @pockets.count %> Kantong</span>
  </div>

  <div class="space-y-4">
    <% @pockets.each do |pocket| %>
      <div class="animate-fade-up group bg-white border-2 border-slate-900 rounded-2xl overflow-hidden transition-all active:scale-[0.98]">
        <%= link_to pocket_path(pocket), class: "block p-4" do %>
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl border-2 border-slate-900 flex items-center justify-center text-3xl shrink-0" 
                 style="background-color: <%= pocket.color %>;">
              <%= pocket.icon %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex justify-between items-center">
                <h4 class="font-black text-slate-900 text-base truncate pr-2"><%= pocket.name %></h4>
                <p class="text-lg font-black text-slate-900"><%= format_money(pocket.current_balance) %></p>
              </div>
              <p class="text-[10px] font-black text-slate-400 uppercase mt-1">Saldo Saat Ini</p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= link_to new_pocket_path, class: "w-full py-4 border-2 border-dashed border-slate-400 rounded-2xl flex flex-col items-center justify-center gap-2 bg-white/50 hover:bg-slate-50 transition-colors active:scale-95" do %>
      <i data-lucide="plus" class="w-6 h-6 text-slate-500"></i>
      <span class="text-[10px] font-black uppercase tracking-widest text-slate-500">Tambah Kantong</span>
    <% end %>
  </div>
</div>
