<div class="space-y-6 pb-24">
  <%# 1. Main Net Balance Card - Kuning (Tanpa Shadow) %>
  <div class="animate-fade-up bg-indigo-400 border-2 border-slate-900 p-6 rounded-3xl relative">
    <div class="absolute top-4 right-4 bg-white/20 px-3 py-1 rounded-full border-2 border-indigo-900/30">
      <p class="text-[9px] font-black uppercase tracking-widest text-white">
        <%= @billing_period.begin.strftime("%d %b") %> - <%= @billing_period.end.strftime("%d %b %Y") %>
      </p>
    </div>
    
    <div class="flex items-center gap-2 mb-1 mt-4">
      <span class="text-xl">💰</span>
      <p class="text-2xs font-black text-slate-900 uppercase tracking-widest">Available Balance</p>
    </div>
    <h2 class="text-4xl font-black text-slate-900"><%= format_money(@net_balance) %></h2>
  </div>

  <%# 2. Income & Expense Split Cards (Tanpa Shadow) %>
  <div class="animate-fade-up grid grid-cols-2 gap-4" style="animation-delay: 100ms">
    <%# Income Card - Hijau Emerald %>
    <div class="bg-lime-400 border-2 border-slate-900 p-4 rounded-3xl">
      <div class="w-8 h-8 bg-white border-2 border-slate-900 rounded-lg flex items-center justify-center mb-3">
        <i data-lucide="arrow-up" class="w-5 h-5 text-lime-600" stroke-width="3"></i>
      </div>
      <p class="text-[9px] font-black text-slate-900 uppercase tracking-widest">Income</p>
      <p class="text-sm font-black text-slate-900 truncate">+<%= format_money(@total_income) %></p>
    </div>

    <%# Expense Card - Rose/Coral %>
    <div class="bg-rose-400 border-2 border-slate-900 p-4 rounded-3xl">
      <div class="w-8 h-8 bg-white border-2 border-slate-900 rounded-lg flex items-center justify-center mb-3">
        <i data-lucide="arrow-down" class="w-5 h-5 text-rose-600" stroke-width="3"></i>
      </div>
      <p class="text-[9px] font-black text-slate-900 uppercase tracking-widest">Expense</p>
      <p class="text-sm font-black text-slate-900 truncate">-<%= format_money(@total_expense) %></p>
    </div>
  </div>
  
  <%# Kantong Cards - Horizontal Scroll %>
  <div class="animate-fade-up" style="animation-delay: 150ms">
    <div class="flex justify-between items-center px-1 mb-3">
      <h3 class="font-black text-xs uppercase tracking-widest text-slate-900">Kantong Saya</h3>
      <%= link_to "Lihat Semua", pockets_path, class: "text-[10px] font-black text-indigo-500 uppercase underline" %>
    </div>
    <div class="flex gap-3 overflow-x-auto pb-4 snap-x snap-mandatory -mx-4 px-4 hide-scrollbar">
      <% @pockets.each do |pocket| %>
        <%= link_to pocket_path(pocket), class: "snap-start shrink-0 w-40 border-2 border-slate-900 p-4 rounded-2xl",
            style: "background-color: #{pocket.color};" do %>
          <div class="text-2xl mb-2"><%= pocket.icon %></div>
          <p class="text-2xs font-black uppercase tracking-widest text-slate-900 opacity-70 truncate"><%= pocket.name %></p>
          <p class="text-sm font-black text-slate-900 truncate"><%= format_money(pocket.current_balance) %></p>
        <% end %>
      <% end %>
      <!-- Add pocket button -->
      <%= link_to new_pocket_path, class: "snap-start shrink-0 w-32 border-2 border-dashed border-slate-400 p-4 rounded-2xl flex flex-col items-center justify-center bg-slate-50/50 hover:bg-slate-100 transition-colors" do %>
        <i data-lucide="plus" class="w-6 h-6 text-slate-400 mb-1"></i>
        <p class="text-2xs font-black text-slate-400 uppercase mt-1">Tambah</p>
      <% end %>
    </div>
  </div>

  <%# 3. Financial Health Card - Neo-Brutalist Style %>
	<div class="animate-fade-up <%= @health[:color] %> border-2 border-slate-900 p-5 rounded-3xl" style="animation-delay: 200ms">
		<div class="flex justify-between items-start mb-4">
			<div>
				<%# Tambahkan mb-1 untuk memberi jarak ke bawah %>
				<p class="text-2xs font-black text-slate-900 uppercase tracking-widest opacity-80 mb-1">
					Financial Health
				</p>
				<%# Gunakan leading-tight agar teks status punya ruang %>
				<h3 class="text-3xl font-black text-slate-900 uppercase italic leading-tight">
					<%= @health[:status] %>
				</h3>
			</div>
			<div class="bg-white border-2 border-slate-900 px-3 py-1 rounded-full font-black text-xs">
				<%= @health[:percent] %>% Ratio
			</div>
		</div>

		<div class="bg-white/40 border-2 border-slate-900 p-3 rounded-2xl">
			<div class="flex gap-3">
				<div class="text-xl">📊</div>
				<p class="text-[11px] font-bold text-slate-900 leading-tight">
					<%= @health[:advice] %>
				</p>
			</div>
		</div>

		<%# Progress Meter (Visualisasi Beban Pengeluaran) %>
		<div class="mt-4 flex gap-1.5">
			<% [20, 40, 60, 80, 100].each do |level| %>
				<div class="h-2.5 flex-1 border-2 border-slate-900 rounded-full 
					<%= @health[:percent] >= level ? 'bg-slate-900' : 'bg-white/20' %>">
				</div>
			<% end %>
		</div>
	</div>

	<%# 4. Recent Transactions Section %>
  <div class="animate-fade-up space-y-4" style="animation-delay: 250ms">
    <div class="flex justify-between items-center px-1">
      <h3 class="font-black text-xs uppercase tracking-widest text-slate-900">Recent Activity</h3>
      <%= link_to "View All", transactions_path, class: "text-[10px] font-black text-indigo-500 uppercase underline" %>
    </div>
    
    <div class="space-y-3">
      <% @recent_transactions.each do |t| %>
        <div class="flex items-center justify-between bg-white border-2 border-slate-900 p-3 rounded-2xl transition-transform active:scale-[0.98]">
          <div class="flex items-center gap-3">
            <div class="w-13 h-13 rounded-xl border-2 border-slate-900 flex items-center justify-center text-3xl" style="background-color: <%= t.category.color %>;">
              <%= t.category.icon %>
            </div>
            <div>
              <p class="font-black text-sm text-slate-900 uppercase"><%= t.description.presence || t.category.name %></p>
              
              <div class="flex items-center gap-1">
                <% if t.transfer? %>
                  <p class="text-2xs font-bold text-slate-400 uppercase">
                    <%= t.source_pocket&.name || 'Unknown' %> <i data-lucide="arrow-right" class="w-3 h-3 inline"></i> <%= t.destination_pocket&.name || 'Unknown' %>
                  </p>
                <% else %>
                  <p class="text-2xs font-bold text-slate-400 uppercase">
                    <%= t.source_pocket&.name || t.destination_pocket&.name || 'Unknown' %>
                  </p>
                <% end %>
                <span class="text-slate-300 mx-1">•</span>
                <p class="text-2xs font-bold text-slate-400 uppercase"><%= t.date.strftime("%d %b") %> <%= t.time&.strftime("%H:%M") %></p>
              </div>
            </div>
          </div>
          <div class="text-right">
            <% if t.transfer? %>
              <p class="font-black text-sm text-slate-500">
                ↔ <%= format_money(t.amount) %>
              </p>
            <% else %>
              <p class="font-black text-sm <%= t.category.category_type == 'expense' ? 'text-rose-500' : 'text-emerald-500' %>">
                <%= t.category.category_type == 'expense' ? '-' : '+' %><%= format_money(t.amount) %>
              </p>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @recent_transactions.empty? %>
        <div class="py-8 text-center border-2 border-dashed border-slate-300 rounded-3xl">
          <p class="text-2xs font-black text-slate-400 uppercase tracking-widest">No recent transactions</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
